<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <script>
      if (!sessionStorage.getItem('jugadorId')) window.location.href = '/public/bienvenida';
    </script>
    <nav class="navbar">
      <div class="navbar-logo">UNO Argentino</div>
      <div class="navbar-info" id="estado-partida">Conectando...</div>
      <button class="btn-toggle-bitacora" id="btn-toggle-bitacora">Actividad</button>
      <div class="navbar-links">
        <span class="navbar-usuario" id="navbar-usuario"></span>
        <button type="button" id="btn-reglas" class="navbar-link navbar-link-button">
          Reglas
        </button>
        <a href="#" id="salir" class="navbar-link">Salir</a>
      </div>
    </nav>

    <div class="lobby">
      <div class="lobby-principal">
        <div id="vista-lobby">
          <h1 id="lobby-titulo">Sala</h1>
          <p id="lobby-info" class="lobby-info"></p>

          <h2 class="lobby-subtitulo">Jugadores</h2>
          <ul id="lista-jugadores" class="lista-jugadores"></ul>

          <button id="btn-iniciar" class="btn-iniciar" hidden>INICIAR PARTIDA</button>
        </div>

        <div id="vista-mesa" class="mesa" hidden></div>
      </div>

      <div class="lobby-bitacora">
        <h2 class="lobby-subtitulo">Actividad</h2>
        <ul id="lista-mensajes" class="lista-mensajes"></ul>
        <form id="form-chat" class="form-chat">
          <input
            id="input-chat"
            type="text"
            maxlength="200"
            placeholder="Escribí un mensaje..."
            autocomplete="off"
          />
          <button type="submit" class="btn-chat">Enviar</button>
        </form>
      </div>
    </div>

    <div id="modal-reglas" class="modal-reglas" hidden aria-hidden="true">
      <div class="modal-reglas-backdrop" data-cerrar-reglas="true"></div>
      <section
        class="modal-reglas-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="modal-reglas-titulo"
      >
        <button
          type="button"
          id="btn-cerrar-reglas"
          class="modal-reglas-cerrar"
          aria-label="Cerrar reglas"
        >
          ×
        </button>
        <div class="modal-reglas-header">
          <h2 id="modal-reglas-titulo">Reglas del juego</h2>
        </div>
        <iframe
          id="iframe-reglas"
          class="modal-reglas-frame"
          title="Reglas de UNO Argentino"
          loading="lazy"
        ></iframe>
      </section>
    </div>

    <script>
      // Re-login silencioso al cargar (cubre F5 y reinicio del server)
      (function () {
        const nombre = sessionStorage.getItem('nombreUsuario');
        if (nombre) {
          fetch('/api/ingresar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nombreUsuario: nombre }),
          }).catch(() => {});
        }
      })();

      // Detección de cierre de navegador (mismo patrón que partials/navbar.ejs)
      document.addEventListener('click', (e) => {
        if (e.target.closest('a[href], [data-nav-interno="true"]')) window.__navInterno = true;
      });
      window.addEventListener('pagehide', () => {
        if (window.__navInterno) return;
        const jugadorId = sessionStorage.getItem('jugadorId');
        if (!jugadorId) return;
        const blob = new Blob([JSON.stringify({ jugadorId })], { type: 'application/json' });
        navigator.sendBeacon('/api/salir', blob);
      });
    </script>
    <script type="module">
      import Partida from '/scripts/partida.js';

      document.getElementById('navbar-usuario').textContent =
        sessionStorage.getItem('nombreUsuario') || '';

      const btnIniciar = document.getElementById('btn-iniciar');
      const partida = new Partida({
        jugadorId: sessionStorage.getItem('jugadorId'),
        partidaId: new URLSearchParams(window.location.search).get('partidaId'),
        estado: document.getElementById('estado-partida'),
        titulo: document.getElementById('lobby-titulo'),
        info: document.getElementById('lobby-info'),
        lista: document.getElementById('lista-jugadores'),
        listaMensajes: document.getElementById('lista-mensajes'),
        vistaLobby: document.getElementById('vista-lobby'),
        vistaMesa: document.getElementById('vista-mesa'),
        lobbyPrincipal: document.querySelector('.lobby-principal'),
        btnToggleBitacora: document.getElementById('btn-toggle-bitacora'),
        panelBitacora: document.querySelector('.lobby-bitacora'),
        inputChat: document.getElementById('input-chat'),
        formChat: document.getElementById('form-chat'),
        onCambioVisibilidad: (visible) => {
          btnIniciar.hidden = !visible;
        },
      });

      document.getElementById('btn-iniciar').addEventListener('click', () => {
        partida.iniciarPartida();
      });

      const btnReglas = document.getElementById('btn-reglas');
      const modalReglas = document.getElementById('modal-reglas');
      const btnCerrarReglas = document.getElementById('btn-cerrar-reglas');
      const iframeReglas = document.getElementById('iframe-reglas');

      const abrirReglas = () => {
        if (!iframeReglas.src) iframeReglas.src = '/public/reglas?embed=1';
        modalReglas.hidden = false;
        modalReglas.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-reglas-abierto');
      };

      const cerrarReglas = () => {
        modalReglas.hidden = true;
        modalReglas.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modal-reglas-abierto');
      };

      btnReglas.addEventListener('click', abrirReglas);
      btnCerrarReglas.addEventListener('click', cerrarReglas);
      modalReglas.addEventListener('click', (e) => {
        if (e.target.closest('[data-cerrar-reglas="true"]')) cerrarReglas();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modalReglas.hidden) cerrarReglas();
      });

      document.getElementById('salir').addEventListener('click', (e) => {
        e.preventDefault();
        partida.salir();
      });

      partida.init();
    </script>
  </body>
</html>
