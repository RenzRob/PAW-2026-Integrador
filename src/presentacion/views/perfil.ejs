<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <%- include('partials/navbar.ejs') %>

    <div class="perfil-container">
      <div class="perfil-box" id="perfil-box">
        <div class="perfil-loading">Cargando perfil...</div>
      </div>
    </div>

    <script>
      const JUGADOR_ID = '<%= jugadorId %>';

      async function cargarPerfil() {
        const box = document.getElementById('perfil-box');
        try {
          const [perfilRes, meRes] = await Promise.all([
            fetch(`/api/perfil/${JUGADOR_ID}`),
            fetch('/api/me'),
          ]);
          if (!perfilRes.ok) throw new Error('No se pudo cargar el perfil.');
          const data = await perfilRes.json();
          const me = meRes.ok ? await meRes.json() : null;
          renderPerfil(data, me?.jugadorId === JUGADOR_ID);
        } catch (err) {
          box.innerHTML = `<p class="perfil-error">${err.message}</p>`;
        }
      }

      function renderPerfil(d, esMiPerfil) {
        const box = document.getElementById('perfil-box');
        const { nombreUsuario, fotoUrl, stats, xpInfo, historial, logros } = d;
        const recompensas = logros
          .filter(l => l.desbloqueado && l.fechaObtenido)
          .sort((a, b) => new Date(b.fechaObtenido) - new Date(a.fechaObtenido));

        const winrateColor = stats.winrate >= 50 ? '#27ae60' : '#c0392b';
        const logrosDesbloqueados = logros.filter(l => l.desbloqueado).length;

        box.innerHTML = `
          <!-- Header del perfil -->
          <div class="perfil-header">
            <div class="perfil-avatar-wrap" id="avatar-wrap">
              ${fotoUrl
                ? `<img class="perfil-avatar-img" src="${fotoUrl}" alt="Foto de perfil">`
                : `<div class="perfil-avatar">${nombreUsuario.charAt(0).toUpperCase()}</div>`
              }
              ${esMiPerfil ? `
                <label class="perfil-avatar-btn" for="avatar-input" title="Cambiar foto de perfil">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                </label>
                <input type="file" id="avatar-input" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none">
              ` : ''}
            </div>
            <div class="perfil-header-info">
              <h1 class="perfil-nombre">${nombreUsuario}</h1>
              <div class="perfil-nivel-badge">Nivel ${stats.nivel}</div>
              <div class="perfil-xp-wrap">
                <div class="perfil-xp-bar">
                  <div class="perfil-xp-fill" style="width: ${xpInfo.progresoNivel}%"></div>
                </div>
                <span class="perfil-xp-label">${xpInfo.xpEnNivel} / ${xpInfo.xpDelNivel} XP</span>
              </div>
              <div class="perfil-puntaje-global">Puntaje global: <strong>${stats.puntajeGlobal}</strong> pts</div>
            </div>
          </div>

          <!-- Stats grid -->
          <div class="perfil-stats-grid">
            <div class="perfil-stat-card">
              <span class="stat-numero">${stats.partidas}</span>
              <span class="stat-label">Partidas</span>
            </div>
            <div class="perfil-stat-card">
              <span class="stat-numero">${stats.victorias}</span>
              <span class="stat-label">Victorias</span>
            </div>
            <div class="perfil-stat-card">
              <span class="stat-numero">${stats.derrotas}</span>
              <span class="stat-label">Derrotas</span>
            </div>
            <div class="perfil-stat-card">
              <span class="stat-numero" style="color: ${winrateColor}">${stats.winrate}%</span>
              <span class="stat-label">Winrate</span>
            </div>
          </div>

          <!-- Tabs: Historial / Logros / Recompensas -->
          <div class="perfil-tabs">
            <button class="perfil-tab perfil-tab--activo" data-tab="historial">Últimas partidas</button>
            <button class="perfil-tab" data-tab="logros">Logros <span class="logros-contador">${logrosDesbloqueados}/${logros.length}</span></button>
            <button class="perfil-tab" data-tab="recompensas">Recompensas ${recompensas.length > 0 ? `<span class="logros-contador">${recompensas.length}</span>` : ''}</button>
          </div>

          <div class="perfil-tab-panel" id="tab-historial">
            ${historial.length === 0
              ? '<p class="perfil-vacio">Todavía no jugaste ninguna partida.</p>'
              : `<div class="perfil-tabla-wrap"><table class="perfil-tabla">
                  <thead><tr><th>Fecha</th><th>Puesto</th><th>Pts. ronda</th><th>Delta</th></tr></thead>
                  <tbody>
                    ${historial.map(h => {
                      const fecha = new Date(h.fecha).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: '2-digit' });
                      const medalla = h.puesto === 1 ? '🥇' : h.puesto === 2 ? '🥈' : h.puesto === 3 ? '🥉' : `${h.puesto}°`;
                      const deltaClass = h.delta_global >= 0 ? 'delta-positivo' : 'delta-negativo';
                      const deltaStr = h.delta_global >= 0 ? `+${h.delta_global}` : `${h.delta_global}`;
                      return `<tr>
                        <td>${fecha}</td>
                        <td>${medalla}</td>
                        <td>${h.puntaje_ronda}</td>
                        <td class="${deltaClass}">${deltaStr}</td>
                      </tr>`;
                    }).join('')}
                  </tbody>
                </table></div>`}
          </div>

          <div class="perfil-tab-panel" id="tab-logros" hidden>
            <div class="logros-grid">
              ${logros.map(l => {
                const cls = l.desbloqueado ? 'logro-card desbloqueado' : 'logro-card bloqueado';
                const fechaStr = l.fechaObtenido
                  ? new Date(l.fechaObtenido).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: '2-digit' })
                  : '';
                return `<div class="${cls}" title="${l.descripcion}">
                  <span class="logro-emoji">${l.desbloqueado ? l.emoji : '🔒'}</span>
                  <span class="logro-nombre">${l.nombre}</span>
                  <span class="logro-desc">${l.descripcion}</span>
                  ${fechaStr ? `<span class="logro-fecha">${fechaStr}</span>` : ''}
                </div>`;
              }).join('')}
            </div>
          </div>

          <div class="perfil-tab-panel" id="tab-recompensas" hidden>
            ${recompensas.length === 0
              ? '<p class="perfil-vacio">Todavía no desbloqueaste ninguna recompensa.</p>'
              : `<div class="recompensas-feed">
                  ${recompensas.map(r => {
                    const fecha = new Date(r.fechaObtenido).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: '2-digit' });
                    const hora = new Date(r.fechaObtenido).toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' });
                    return `<div class="recompensa-item">
                      <span class="recompensa-emoji">${r.emoji}</span>
                      <div class="recompensa-info">
                        <span class="recompensa-nombre">${r.nombre}</span>
                        <span class="recompensa-desc">${r.descripcion}</span>
                      </div>
                      <span class="recompensa-fecha">${fecha}<br><small>${hora}</small></span>
                    </div>`;
                  }).join('')}
                </div>`}
          </div>

          <button class="btn-perfil-volver" onclick="window.location.href='/public/'">VOLVER AL INICIO</button>
        `;

        document.querySelectorAll('.perfil-tab').forEach(btn => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('.perfil-tab').forEach(b => b.classList.remove('perfil-tab--activo'));
            document.querySelectorAll('.perfil-tab-panel').forEach(p => p.hidden = true);
            btn.classList.add('perfil-tab--activo');
            document.getElementById('tab-' + btn.dataset.tab).hidden = false;
          });
        });

        if (esMiPerfil) {
          const input = document.getElementById('avatar-input');
          input.addEventListener('change', async () => {
            const file = input.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('avatar', file);

            const btn = document.querySelector('.perfil-avatar-btn');
            if (btn) btn.classList.add('cargando');

            try {
              const res = await fetch('/api/perfil/avatar', { method: 'POST', body: formData });
              const data = await res.json();
              if (!res.ok) {
                alert(data.error || 'Error al subir la foto');
                return;
              }

              const wrap = document.getElementById('avatar-wrap');
              const anterior = wrap.querySelector('.perfil-avatar, .perfil-avatar-img');
              if (anterior) anterior.remove();

              const img = document.createElement('img');
              img.className = 'perfil-avatar-img';
              img.alt = 'Foto de perfil';
              img.src = data.fotoUrl + '?t=' + Date.now();
              wrap.insertBefore(img, wrap.firstChild);
            } catch {
              alert('Error al subir la foto');
            } finally {
              if (btn) btn.classList.remove('cargando');
              input.value = '';
            }
          });
        }
      }

      cargarPerfil();
    </script>
  </body>
</html>
