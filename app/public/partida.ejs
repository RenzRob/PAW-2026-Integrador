<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <script>
      // Si el ID del usuario no está almacenado en la sesión, redirige a la página de bienvenida.
      if (!sessionStorage.getItem('jugadorId')) window.location.href = '/public/bienvenida';
    </script>

    <nav class="navbar">
      <div class="navbar-logo">UNO Argentino</div>
      <div class="navbar-info" id="estado-partida">Conectando...</div>
      <div class="navbar-links">
        <span class="navbar-usuario" id="navbar-usuario"></span>
        <a href="#" id="salir" class="navbar-link">Salir</a>
      </div>
    </nav>

    <!-- Lobby -->
    <div class="lobby">
      <!-- Lobby de juego -->
      <div class="lobby-principal">
        <div id="vista-lobby">
          <h1 id="lobby-titulo">Sala</h1>
          <p id="lobby-info" class="lobby-info"></p>

          <h2 class="lobby-subtitulo">Jugadores</h2>
          <ul id="lista-jugadores" class="lista-jugadores"></ul>

          <button id="btn-iniciar" class="btn-iniciar" hidden>INICIAR PARTIDA</button>
        </div>

        <div id="vista-mesa" class="mesa" hidden></div>
      </div>

      <!-- Bitácora de actividades -->
      <div class="lobby-bitacora">
        <h2 class="lobby-subtitulo">Actividad</h2>
        <ul id="lista-mensajes" class="lista-mensajes"></ul>
      </div>
    </div>

    <script type="module">
      import Partida from '/scripts/partida.js';

      // Establece el nombre del usuario en la barra de navegación utilizando el valor almacenado en sessionStorage.
      document.getElementById('navbar-usuario').textContent =
        sessionStorage.getItem('nombreUsuario') || '';

      const btnIniciar = document.getElementById('btn-iniciar');
      const partida = new Partida({
        jugadorId: sessionStorage.getItem('jugadorId'),
        partidaId: new URLSearchParams(window.location.search).get('partidaId'),
        estado: document.getElementById('estado-partida'),
        titulo: document.getElementById('lobby-titulo'),
        info: document.getElementById('lobby-info'),
        lista: document.getElementById('lista-jugadores'),
        listaMensajes: document.getElementById('lista-mensajes'),
        vistaLobby: document.getElementById('vista-lobby'),
        vistaMesa: document.getElementById('vista-mesa'),
        lobbyPrincipal: document.querySelector('.lobby-principal'),
        onCambioVisibilidad: (visible) => {
          btnIniciar.hidden = !visible;
        },
      });

      document.getElementById('btn-iniciar').addEventListener('click', () => {
        partida.iniciarPartida();
      });

      document.getElementById('salir').addEventListener('click', (e) => {
        e.preventDefault();
        partida.salir();
      });

      partida.init();
    </script>
  </body>
</html>
