<style>
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 20px;
    background-color: #1a4971;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .topbar-logo {
    font-size: 18px;
    font-weight: bold;
    letter-spacing: 1px;
    color: white;
  }

  .topbar-usuario {
    font-size: 14px;
    color: white;
    font-weight: bold;
  }
</style>
<nav class="topbar">
  <div class="topbar-logo">UNO Argentino</div>
  <div class="topbar-usuario" id="topbar-usuario"></div>
</nav>
<script>
  (function () {
    const nombre = sessionStorage.getItem('nombreUsuario');
    if (nombre) document.getElementById('topbar-usuario').textContent = nombre;

    // Re-login silencioso al cargar la página: cubre el caso de F5/recarga
    // (donde el pagehide previo nos deslogueó) y reinicio del server.
    // Si ya estás logueado, /api/ingresar devuelve 409 y no pasa nada.
    if (nombre) {
      fetch('/api/ingresar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombreUsuario: nombre }),
      }).catch(() => {});
    }

    // Detección de cierre de navegador/pestaña: si el usuario navega dentro de
    // la app (click en link/botón), se setea __navInterno y NO se desloguea.
    // Si el usuario cierra la pestaña/navegador, se dispara sendBeacon a /api/salir
    // para liberar el nombre.
    document.addEventListener('click', (e) => {
      if (e.target.closest('a[href], button')) window.__navInterno = true;
    });

    window.addEventListener('pagehide', () => {
      if (window.__navInterno) return;
      const jugadorId = sessionStorage.getItem('jugadorId');
      if (!jugadorId) return;
      const blob = new Blob([JSON.stringify({ jugadorId })], { type: 'application/json' });
      navigator.sendBeacon('/api/salir', blob);
    });
  })();
</script>
